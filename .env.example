DATABASE_URL=postgres://griffiths_crm_app:supersecretpassword@localhost:5432/griffiths_crm
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# S3 Configuration (for image uploads)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# For local development with LocalStack, set:
# S3_ENDPOINT=http://localhost:4566

# TakePayments Configuration
TAKEPAYMENTS_ENCRYPTION_KEY=   # 32-byte hex (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYMENT_TOKEN_SECRET=           # 32-byte hex for payment link HMAC tokens
API_BASE_URL=http://localhost:3000   # Backend public URL (for ServerResultURL + CallbackURL)
APP_URL=http://localhost:5173        # Frontend public URL (for redirect destinations)
