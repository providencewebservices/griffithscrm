COMPOSE_PROJECT_NAME=griffiths-crm
POSTGRES_PORT=5433
SMTP_PORT=1026
MAILPIT_UI_PORT=8026
LOCALSTACK_PORT=4577

DATABASE_URL=postgres://griffiths_crm_app:supersecretpassword@localhost:5433/griffiths_crm
# Production uses Neon PostgreSQL 17 with two connection strings:
# DATABASE_URL        — pooled connection (PgBouncer) for application queries
# DATABASE_URL_DIRECT — direct connection for migrations (bypasses PgBouncer)
# DATABASE_URL_DIRECT is not needed locally (Docker Compose postgres has no pooler)
# If you change POSTGRES_PORT for a concurrent local stack, keep DATABASE_URL in sync.
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# S3 Configuration (for image uploads)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# For local development with LocalStack, set:
# S3_ENDPOINT=http://localhost:4577
SMTP_HOST=localhost
SMTP_PORT=1026

# TakePayments Configuration
TAKEPAYMENTS_ENCRYPTION_KEY=   # 32-byte hex (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYMENT_TOKEN_SECRET=           # 32-byte hex for payment link HMAC tokens
API_BASE_URL=http://localhost:3000   # Backend public URL (for ServerResultURL + CallbackURL)
APP_URL=http://localhost:5173        # Frontend public URL (for redirect destinations)
