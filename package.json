{
  "name": "griffiths-crm",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --parallel dev:api dev:web",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --parallel build:api build:web",
    "build:api": "bun run --cwd apps/api build",
    "build:web": "bun run --cwd apps/web build",
    "db:generate": "bun run --cwd packages/shared db:generate",
    "db:migrate": "bun run --cwd packages/shared db:migrate",
    "db:push": "bun run --cwd packages/shared db:push",
    "db:studio": "bun run --cwd packages/shared db:studio",
    "db:bootstrap": "bun run --cwd apps/api scripts/bootstrap-admin.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.965.0",
    "@radix-ui/react-radio-group": "^1.3.8",
    "drizzle-orm": "latest",
    "nodemailer": "^7.0.12",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/nodemailer": "^7.0.5",
    "dotenv": "^16.4.7",
    "shadcn": "^3.5.1",
    "typescript": "^5.7.2"
  }
}
